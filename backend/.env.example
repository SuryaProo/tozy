# ─────────────────────────────────────────────
# Copy this file to ".env" and fill in your values.
# Never commit the real .env file.
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB — paste your Atlas connection string here.
# Get it from: MongoDB Atlas → Database → Connect → Drivers
# Example: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/tozycozy?retryWrites=true&w=majority
MONGODB_URI=

# JWT — use any long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=30d

# CORS — your frontend URL(s), comma-separated if more than one
CORS_ORIGIN=http://localhost:3000

# ── Optional: real SMS provider for OTP (leave blank to use console-log dev mode) ──
# TWILIO_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE=
# MSG91_KEY=
FRONTEND_URL=http://localhost:3000

# ── Dev OTP visibility ──
# Set SHOW_DEV_OTP=true ONLY during local testing to see OTP on screen
# Remove this line in production — OTP will only go via SMS/email
# SHOW_DEV_OTP=true
